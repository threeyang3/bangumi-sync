{
	"compilerOptions": {
		"inlineSourceMap": true,
		"inlineSources": true,
		"module": "ESNext",
		"target": "ES6",
		"allowJs": true,
		"strict": true,
		"moduleResolution": "node",
		"importHelpers": true,
		"isolatedModules": true,
		"lib": [
			"DOM",
			"ES2017"
		],
		"outDir": "dist",
		"rootDir": ".",
		"skipLibCheck": true
	},
	"include": [
		"**/*.ts"
	]
}
